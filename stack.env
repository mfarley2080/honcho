DOMAIN=honcho.lre-group.org
DATA_PATH=/mnt/tank/docker/honcho
AUTH_USE_AUTH=false
LOG_LEVEL=INFO

# LiteLLM
LITELLM_BASE_URL=https://litellm.lre-group.org/v1
LLM_MODEL=claude-3-5-haiku-20241022
EMBEDDING_MODEL=mxbai-embed-large
EMBEDDING_DIMENSIONS=1024

# LITELLM_API_KEY, DB_PASSWORD, AUTH_JWT_SECRET, and AUTH_USE_AUTH
# must be set as environment overrides in Portainer — do not commit secrets here
