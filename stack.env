DOMAIN=honcho.lre-group.org
DATA_PATH=/mnt/tank/docker/honcho
AUTH_USE_AUTH=false
LOG_LEVEL=INFO

# Deriver
# DERIVER_FLUSH_ENABLED=false  # Set to true to bypass the 1024-token batch threshold — useful for testing

# LLM (deriver, dialectic, summary, dream) — routed through LiteLLM
LLM_BASE_URL=https://litellm.lre-group.org/v1
LLM_MODEL=gpt-5.4-mini

# Embeddings — separate endpoint/key so it can point at a different provider
EMBEDDING_BASE_URL=https://litellm.lre-group.org/v1
EMBEDDING_MODEL=mxbai-embed-large
EMBEDDING_DIMENSIONS=1024

# LLM_API_KEY, EMBEDDING_API_KEY, DB_PASSWORD, AUTH_JWT_SECRET, and AUTH_USE_AUTH
# must be set as environment overrides in Portainer — do not commit secrets here
